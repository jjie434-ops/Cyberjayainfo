const navToggle = document.querySelector(".nav-toggle");
const siteNav = document.querySelector(".site-nav");
const enquiryForm = document.querySelector(".enquiry-form");
const whatsappUrl = "https://wa.link/spjgoe";

navToggle?.addEventListener("click", () => {
  const isOpen = siteNav.classList.toggle("is-open");
  navToggle.setAttribute("aria-expanded", String(isOpen));
});

siteNav?.addEventListener("click", (event) => {
  if (event.target instanceof HTMLAnchorElement) {
    siteNav.classList.remove("is-open");
    navToggle?.setAttribute("aria-expanded", "false");
  }
});

enquiryForm?.addEventListener("submit", (event) => {
  event.preventDefault();

  window.open(whatsappUrl, "_blank", "noopener,noreferrer");
});

:root {
  --ink: #3d2924;
  --muted: #775e56;
  --line: #e2d6cf;
  --paper: #f4ede8;
  --white: #fffdf9;
  --clay: #a66f5b;
  --rust: #7f2e1f;
  --mist: #dfe8ec;
  --lake: #345b66;
  --charcoal: #1f2527;
  --shadow: 0 22px 60px rgba(61, 41, 36, 0.16);
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  color: var(--ink);
  background: var(--paper);
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  line-height: 1.6;
}

img {
  display: block;
  max-width: 100%;
}

a {
  color: inherit;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  min-height: 76px;
  align-items: center;
  justify-content: space-between;
  padding: 14px clamp(18px, 5vw, 68px);
  border-bottom: 1px solid rgba(226, 214, 207, 0.82);
  background: rgba(244, 237, 232, 0.9);
  backdrop-filter: blur(18px);
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
}

.brand-mark {
  display: grid;
  width: 58px;
  height: 42px;
  place-items: center;
  color: var(--white);
  background: var(--rust);
  border-radius: 8px;
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: 24px;
  font-weight: 700;
  line-height: 1;
}

.brand strong,
.brand small {
  display: block;
}

.brand strong {
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: 24px;
  line-height: 1;
}

.brand small {
  color: var(--muted);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0;
}

.site-nav {
  display: flex;
  align-items: center;
  gap: 24px;
  color: var(--muted);
  font-size: 14px;
  font-weight: 800;
}

.site-nav a {
  text-decoration: none;
}

.site-nav a:hover {
  color: var(--rust);
}

.nav-toggle {
  display: none;
  width: 42px;
  height: 42px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--white);
}

.nav-toggle span {
  display: block;
  width: 18px;
  height: 2px;
  margin: 4px auto;
  background: var(--ink);
}

.hero {
  position: relative;
  min-height: calc(100vh - 76px);
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(340px, 0.65fr);
  align-items: stretch;
  background: var(--clay);
  border-bottom: 1px solid var(--line);
}

.hero-media {
  min-height: 660px;
  background:
    linear-gradient(90deg, rgba(31, 37, 39, 0.04), rgba(31, 37, 39, 0.34)),
    url("assets/myra-cove-lake-day.jpeg") center / cover;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: clamp(42px, 8vw, 112px) clamp(24px, 5vw, 68px) 152px;
  color: var(--white);
}

.eyebrow {
  margin: 0 0 14px;
  color: var(--rust);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0;
  text-transform: uppercase;
}

.hero .eyebrow,
.contact-section .eyebrow,
.split-showcase .eyebrow {
  color: #ffece4;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1,
h2 {
  font-family: "Cormorant Garamond", Georgia, serif;
  line-height: 0.98;
}

h1 {
  max-width: 520px;
  margin-bottom: 8px;
  font-size: clamp(72px, 9vw, 130px);
  font-weight: 700;
}

h2 {
  margin-bottom: 18px;
  font-size: clamp(42px, 5.6vw, 76px);
  font-weight: 600;
}

h3 {
  margin-bottom: 10px;
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: 32px;
  line-height: 1.05;
}

.hero-line {
  margin-bottom: 18px;
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: clamp(28px, 3vw, 42px);
  font-style: italic;
  line-height: 1.08;
}

.lead {
  max-width: 520px;
  color: #fff2eb;
  font-size: 18px;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 16px;
}

.btn {
  display: inline-flex;
  min-height: 48px;
  align-items: center;
  justify-content: center;
  gap: 9px;
  padding: 0 18px;
  border: 1px solid transparent;
  border-radius: 8px;
  font-weight: 900;
  text-decoration: none;
  cursor: pointer;
}

.btn svg {
  width: 18px;
  height: 18px;
  fill: currentColor;
}

.btn-primary {
  color: var(--white);
  background: var(--rust);
}

.btn-primary:hover {
  background: #642115;
}

.btn-secondary {
  color: var(--ink);
  background: var(--white);
  border-color: var(--line);
}

.quick-facts {
  position: absolute;
  right: clamp(18px, 5vw, 68px);
  bottom: 32px;
  left: clamp(18px, 5vw, 68px);
  display: grid;
  grid-template-columns: repeat(4, minmax(120px, 1fr));
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.5);
  border-radius: 8px;
  background: rgba(255, 253, 249, 0.9);
  box-shadow: var(--shadow);
  backdrop-filter: blur(16px);
}

.quick-facts div {
  padding: 22px;
  border-right: 1px solid var(--line);
}

.quick-facts div:last-child {
  border-right: 0;
}

.quick-facts strong,
.quick-facts span {
  display: block;
}

.quick-facts strong {
  color: var(--rust);
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: 32px;
  line-height: 1;
}

.quick-facts .range-value {
  max-width: 210px;
  font-size: 26px;
  line-height: 1.05;
}

.quick-facts span {
  color: var(--muted);
  font-size: 13px;
  font-weight: 800;
}

.section {
  padding: clamp(72px, 10vw, 124px) clamp(18px, 5vw, 68px);
}

.section-heading {
  max-width: 840px;
  margin-bottom: 34px;
}

.intro-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: clamp(24px, 5vw, 70px);
  color: var(--muted);
  font-size: 20px;
}

.split-showcase {
  display: grid;
  grid-template-columns: minmax(300px, 0.48fr) minmax(0, 1fr);
  min-height: 620px;
  background: var(--clay);
}

.showcase-copy {
  display: flex;
  flex-direction: column;
  justify-content: end;
  padding: clamp(48px, 7vw, 110px) clamp(24px, 6vw, 74px);
  color: var(--white);
}

.showcase-copy p:not(.eyebrow) {
  max-width: 460px;
  color: #fff2eb;
  font-size: 18px;
}

.split-showcase img {
  width: 100%;
  height: 100%;
  min-height: 540px;
  object-fit: cover;
}

.features {
  background: var(--white);
}

.feature-list {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1px;
  border: 1px solid var(--line);
  background: var(--line);
}

.feature-list article {
  min-height: 310px;
  padding: 28px;
  background: var(--white);
}

.feature-list span {
  display: inline-grid;
  width: 42px;
  height: 42px;
  margin-bottom: 42px;
  place-items: center;
  color: var(--white);
  background: var(--clay);
  border-radius: 8px;
  font-weight: 900;
}

.feature-list p {
  color: var(--muted);
}

.image-band {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
  align-items: center;
  gap: clamp(28px, 6vw, 72px);
  padding: clamp(38px, 6vw, 76px) clamp(18px, 5vw, 68px);
  color: var(--white);
  background: var(--lake);
}

.image-band img {
  width: 100%;
  aspect-ratio: 16 / 10;
  object-fit: cover;
  border-radius: 8px;
  box-shadow: 0 28px 70px rgba(0, 0, 0, 0.22);
}

.image-band .eyebrow {
  color: #d6edf2;
}

.image-band p:not(.eyebrow) {
  max-width: 620px;
  color: #eef7f8;
  font-size: 18px;
}

.gallery-strip {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
}

.gallery-strip img {
  width: 100%;
  height: 380px;
  object-fit: cover;
}

.layout-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.layout-grid article {
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--white);
  box-shadow: 0 16px 42px rgba(61, 41, 36, 0.09);
}

.layout-grid img {
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: contain;
  padding: 12px;
  background: #ece4df;
}

.layout-grid div {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 16px;
  border-top: 1px solid var(--line);
}

.layout-grid strong {
  color: var(--rust);
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: 28px;
  line-height: 1;
}

.layout-grid span {
  color: var(--muted);
  font-size: 13px;
  font-weight: 800;
  text-align: right;
}

.contact-section {
  display: grid;
  grid-template-columns: minmax(280px, 0.9fr) minmax(320px, 1fr);
  gap: clamp(28px, 6vw, 72px);
  padding: clamp(72px, 10vw, 124px) clamp(18px, 5vw, 68px);
  color: var(--white);
  background:
    linear-gradient(90deg, rgba(61, 41, 36, 0.94), rgba(61, 41, 36, 0.72)),
    url("assets/page-3.png") center / cover;
}

.contact-section p:not(.eyebrow) {
  max-width: 600px;
  color: #fff2eb;
  font-size: 18px;
}

.enquiry-form {
  display: grid;
  gap: 16px;
  padding: clamp(18px, 4vw, 32px);
  border: 1px solid rgba(255, 255, 255, 0.24);
  border-radius: 8px;
  background: rgba(255, 253, 249, 0.14);
  backdrop-filter: blur(18px);
}

label {
  display: grid;
  gap: 8px;
  color: var(--white);
  font-size: 13px;
  font-weight: 900;
}

input,
select {
  width: 100%;
  min-height: 48px;
  padding: 0 13px;
  color: var(--ink);
  border: 1px solid rgba(255, 255, 255, 0.32);
  border-radius: 8px;
  background: var(--white);
  font: inherit;
}

.form-note {
  margin: 0;
  color: #fff2eb;
  font-size: 13px;
}

footer {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 12px;
  padding: 24px clamp(18px, 5vw, 68px);
  color: var(--muted);
  background: var(--white);
  border-top: 1px solid var(--line);
  font-size: 13px;
}

footer p {
  margin: 0;
}

@media (max-width: 1080px) {
  .feature-list,
  .layout-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 900px) {
  .site-nav {
    position: fixed;
    top: 76px;
    right: 18px;
    left: 18px;
    display: none;
    flex-direction: column;
    align-items: flex-start;
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--white);
    box-shadow: var(--shadow);
  }

  .site-nav.is-open {
    display: flex;
  }

  .nav-toggle {
    display: inline-block;
  }

  .hero,
  .split-showcase,
  .image-band,
  .contact-section,
  .intro-grid {
    grid-template-columns: 1fr;
  }

  .hero {
    background: var(--paper);
  }

  .hero-media {
    min-height: 56vh;
  }

  .hero-copy {
    color: var(--ink);
    padding-bottom: 220px;
  }

  .hero .eyebrow {
    color: var(--rust);
  }

  .lead,
  .hero-line {
    color: var(--muted);
  }

  .quick-facts {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .quick-facts div:nth-child(2) {
    border-right: 0;
  }

  .quick-facts div:nth-child(1),
  .quick-facts div:nth-child(2) {
    border-bottom: 1px solid var(--line);
  }

  .gallery-strip {
    grid-template-columns: 1fr;
  }

  .gallery-strip img {
    height: auto;
  }
}

@media (max-width: 620px) {
  .site-header {
    min-height: 68px;
  }

  .site-nav {
    top: 68px;
  }

  .brand-mark {
    width: 50px;
    font-size: 21px;
  }

  .brand small {
    display: none;
  }

  h1 {
    font-size: 68px;
  }

  h2 {
    font-size: 42px;
  }

  .hero-media {
    min-height: 430px;
  }

  .hero-copy {
    padding-bottom: 300px;
  }

  .quick-facts,
  .feature-list,
  .layout-grid {
    grid-template-columns: 1fr;
  }

  .quick-facts div {
    padding: 16px 18px;
    border-right: 0;
    border-bottom: 1px solid var(--line);
  }

  .quick-facts div:last-child {
    border-bottom: 0;
  }

  .btn {
    width: 100%;
  }

  .layout-grid div {
    align-items: flex-start;
    flex-direction: column;
  }

  .layout-grid span {
    text-align: left;
  }
}
